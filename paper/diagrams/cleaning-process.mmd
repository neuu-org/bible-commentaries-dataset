        C1 --> C2 --> C3 --> C4 --> C5 --> C6
    end

    OUTPUT["Arquivo limpo\n01_cleaned"]

    INPUT --> CLEAN --> OUTPUT

    style INPUT fill:#fff3e0,stroke:#e65100,stroke-width:2px,color:#333
    style OUTPUT fill:#e8f5e9,stroke:#2e7d32,stroke-width:2px,color:#333
