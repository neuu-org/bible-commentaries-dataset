flowchart TD
    INPUT["Arquivo bruto\n00_raw"]

    subgraph CLEAN["Operações do clean.py"]
        direction TB
        C1["1. ftfy.fix_text\nCorrige mojibake e encoding"]
        C2["2. Remove metadados de scraping\n5 campos top-level + 6 por comentário"]
